{
  "imports": {
    "@aai/sdk": "../sdk/mod.ts",
    "@aai/sdk/types": "../sdk/types.ts",
    "@aai/core/protocol": "../core/protocol.ts",
    "@aai/core/worker-shim": "../core/_worker_shim.ts",
    "@aai/core/types": "../core/types.ts",
    "@aai/ui": "../ui/mod.ts",
    "zod": "jsr:@zod/zod@^4",
    "preact/hooks": "npm:preact@^10/hooks",
    "preact/compat": "npm:preact@^10/compat",
    "react": "npm:preact@^10/compat",
    "react-dom": "npm:preact@^10/compat",
    "@preact/signals": "npm:@preact/signals@^2"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "semiColons": true,
    "singleQuote": false,
    "indentWidth": 2
