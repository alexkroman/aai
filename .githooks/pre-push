#!/bin/sh

protected_branch="main"

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/$protected_branch" ]; then
    echo "ERROR: Direct push to '$protected_branch' is not allowed."
    echo "Please create a pull request instead."
    exit 1
  fi
done

echo "Verifying binary compiles..."
# --no-check: full type-checking already runs in pre-commit (deno task check)
# This just verifies the binary builds and runs correctly.
npm_includes=""
for pkg in preact @preact+signals @preact+signals-core goober esbuild-wasm; do
  dir=$(ls -d node_modules/.deno/${pkg}@* 2>/dev/null | head -1)
  [ -n "$dir" ] && npm_includes="$npm_includes --include $dir"
done
deno compile \
  --no-check \
  --allow-all \
  --unstable-worker-options \
  --include templates/ \
  --include sdk/ \
  --include core/ \
  --include ui/ \
  --include cli/claude.md \
  --include cli/deno.json \
  --include _bundler_config.json \
  $npm_includes \
  --output /tmp/aai-compile-check \
  cli/cli.ts || exit 1
/tmp/aai-compile-check --version || exit 1
rm -f /tmp/aai-compile-check
echo "Binary compile OK"
