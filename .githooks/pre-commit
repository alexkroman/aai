#!/bin/sh

branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  echo "Direct commits to $branch are not allowed. Create a feature branch first."
  exit 1
fi

echo "Auto-bumping versions for changed packages..."
deno task bump

echo "Updating CLI snapshots after version bump..."
deno test --allow-all --unstable-worker-options cli/cli_test.ts -- --update && git add cli/__snapshots__/

echo "Running checks before commit..."
deno task check
