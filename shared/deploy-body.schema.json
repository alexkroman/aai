{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deploy request body",
  "description": "Payload sent to the /deploy endpoint.",
  "type": "object",
  "required": ["slug", "env", "worker", "client"],
  "properties": {
    "slug": {
      "type": "string",
      "minLength": 1,
      "description": "Unique agent identifier."
    },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Resolved environment variables (name → value)."
    },
    "worker": {
      "type": "string",
      "minLength": 1,
      "description": "Bundled worker JavaScript source."
    },
    "client": {
      "type": "string",
      "minLength": 1,
      "description": "Bundled client JavaScript source."
    },
    "transport": {
      "description": "Transport protocols. Defaults to [\"websocket\"].",
      "oneOf": [
        { "enum": ["websocket", "twilio"] },
        {
          "type": "array",
          "items": { "enum": ["websocket", "twilio"] }
        }
      ]
    }
  },
  "additionalProperties": false
}
