{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent environment",
  "description": "Required environment variables for an agent.",
  "type": "object",
  "required": ["ASSEMBLYAI_API_KEY"],
  "properties": {
    "ASSEMBLYAI_API_KEY": {
      "type": "string",
      "minLength": 1,
      "description": "AssemblyAI API key for speech-to-text."
    },
    "LLM_MODEL": {
      "type": "string",
      "description": "LLM model override. Defaults to claude-haiku-4-5."
    }
  },
  "additionalProperties": { "type": "string" }
}
