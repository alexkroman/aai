{
  "version": "0.1.3",
  "workspace": ["server", "ui", "cli"],
  "tasks": {
    "setup": "git config core.hooksPath .githooks",
    "dev": "deno run --allow-net --allow-env --allow-read --allow-write --allow-run --unstable-worker-options cli/cli.ts dev",
    "serve": "deno run --allow-net --allow-env --allow-read --allow-write --unstable-worker-options server/main.ts",
    "types": "deno run --allow-write --allow-env --allow-read cli/cli.ts types",
    "deploy": "deno run --allow-net --allow-env --allow-read --allow-write --allow-run cli/cli.ts deploy",
    "test": "deno test --allow-net --allow-read --allow-write --allow-env --allow-run --unstable-worker-options",
    "check": "deno check server/**/*.ts ui/**/*.ts ui/**/*.tsx cli/**/*.ts templates/**/*.ts && deno lint && deno fmt --check && deno test --quiet --allow-net --allow-read --allow-write --allow-env --allow-run --unstable-worker-options",
    "install-dev": "echo '#!/bin/sh\nINIT_CWD=\"$(pwd)\" exec deno run --allow-all --unstable-worker-options '\"$(pwd)/cli/cli.ts\"' \"$@\"' > \"$HOME/.deno/bin/aai-dev\" && chmod +x \"$HOME/.deno/bin/aai-dev\" && echo 'Installed aai-dev to ~/.deno/bin/aai-dev'"
  },
  "imports": {
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.9",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/async": "jsr:@std/async@^1.2.0",
    "@std/dotenv": "jsr:@std/dotenv@0.225.6",
    "@std/html": "jsr:@std/html@^1.0.5",
    "@std/bytes": "jsr:@std/bytes@^1.0.6",
    "@std/encoding": "jsr:@std/encoding@^1.0.7",
    "@astral/astral": "jsr:@astral/astral@^0.5.5",
    "preact": "npm:preact@^10.28.4",
    "preact/hooks": "npm:preact@^10.28.4/hooks",
    "preact/compat": "npm:preact@^10.28.4/compat",
    "@preact/signals": "npm:@preact/signals@^2.8.1",
    "goober": "npm:goober@^2.1.18",
    "zod": "npm:zod@^4.3.6",
    "esbuild": "npm:esbuild@^0.27.3"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "types": ["./types.d.ts"],
    "lib": [
      "deno.ns",
      "deno.unstable",
      "deno.window",
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "fmt": {
    "include": [
      "server/",
      "ui/",
      "cli/",
      "templates/"
    ]
  },
  "lint": {
    "include": [
      "server/",
      "ui/",
      "cli/",
      "templates/"
    ],
    "rules": {
      "include": ["no-slow-types"]
    }
  },
  "license": "MIT"
}
