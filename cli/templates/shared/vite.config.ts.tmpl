import process from "node:process";
import { defineConfig } from "vite";
import preact from "@preact/preset-vite";
import tailwindcss from "@tailwindcss/vite";
import { viteSingleFile } from "vite-plugin-singlefile";
import { dirname, resolve } from "node:path";
import { fileURLToPath } from "node:url";

const root = dirname(fileURLToPath(import.meta.url));
const devRoot = process.env.AAI_DEV_ROOT;
const buildTarget = process.env.AAI_BUILD_TARGET;

const devAlias = devRoot
  ? {
    "@jsr/aai__sdk": resolve(devRoot, "sdk/mod.ts"),
    "@jsr/aai__ui": resolve(devRoot, "ui/mod.ts"),
    "@aai/sdk/protocol": resolve(devRoot, "sdk/protocol.ts"),
    "@aai/sdk": resolve(devRoot, "sdk/mod.ts"),
    "zod": "@jsr/zod__zod",
    "json-schema": "@jsr/types__json-schema",
    "@std/async": "@jsr/std__async",
    "@std/log": "@jsr/std__log",
  }
  : {};

const workerConfig = defineConfig({
  build: {
    outDir: resolve(root, ".aai/build"),
    emptyOutDir: true,
    lib: {
      entry: resolve(root, ".aai/_worker.ts"),
      formats: ["es"],
      fileName: () => "worker.js",
    },
    minify: true,
    target: "es2022",
    rollupOptions: {
      output: { inlineDynamicImports: true },
    },
  },
  resolve: { alias: devAlias },
});

const clientConfig = defineConfig({
  plugins: [preact(), tailwindcss(), viteSingleFile()],
  build: {
    outDir: resolve(root, ".aai/build"),
    emptyOutDir: true,
    rollupOptions: {
      input: resolve(root, ".aai/index.html"),
    },
  },
  resolve: { alias: devAlias },
});

export default buildTarget === "worker" ? workerConfig : clientConfig;
