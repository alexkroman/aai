{
  "name": "@aai/server",
  "version": "0.1.206",
  "exports": {
    ".": "./main.ts",
    "./types": "./types.ts",
    "./testing": "./_test_utils.ts"
  },
  "imports": {
    "@aai/sdk": "workspace:@aai/sdk",
    "capnweb": "npm:capnweb@^0.1",
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.1001.0",
    "@upstash/redis": "npm:@upstash/redis@^1.36.1",
    "@upstash/vector": "npm:@upstash/vector@^1",
    "ai": "npm:ai@^4",
    "ai/test": "npm:ai@^4/test",
    "@ai-sdk/anthropic": "npm:@ai-sdk/anthropic@^1",
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^1",
    "mdream": "npm:mdream@^0",
    "openai": "npm:openai@^4.80.0",
    "assemblyai": "npm:assemblyai@^4",
    "ws": "npm:ws@^8",
    "preact": "npm:preact@^10.28.4",
    "preact-render-to-string": "npm:preact-render-to-string@^6.5.13"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "publish": {
    "exclude": [
      "*_test.ts",
      "*_test.tsx"
    ]
  },
  "lint": {
    "rules": {
      "exclude": [
        "require-await"
      ]
    }
  }
}
